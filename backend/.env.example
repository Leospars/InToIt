# ── INTOIT Backend — Environment Variables ──────────────────
# Copy this file to .env and fill in your values

ENVIRONMENT=development

# Supabase (required for user progress sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic (optional — only needed for server-side proxy route)
ANTHROPIC_API_KEY=sk-ant-...

# Security
SECRET_KEY=change-me-to-a-random-64-char-string

# # CORS — add your Vercel preview URLs here
# CORS_ORIGINS=["http://localhost:5173","https://intoit.vercel.app"]

GEMINI_API_KEY=the-real-api-key